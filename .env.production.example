# Olatricity ERP — Production environment (AWS EC2 / Docker)
# Copy to .env on the server: cp .env.production.example .env
# NEVER commit the real .env file.

# --- Required for production ---
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=generate-with-python-secrets-token_hex-32

# Public HTTPS URL (required for WhatsApp/Twilio webhooks)
PUBLIC_SITE_URL=https://erp.yourdomain.com
WEBHOOK_BASE_URL=https://erp.yourdomain.com

# --- SQLite on persistent storage (EBS / Docker volume) ---
DATABASE_PATH=/var/lib/olatricity/data/3G_ERP_V1.db

# --- App server (Gunicorn behind nginx) ---
APP_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_TIMEOUT=120
LOG_DIR=/var/log/olatricity
LOG_LEVEL=INFO

# --- Waitress (optional — use run.py on Windows dev only) ---
# WAITRESS_THREADS=16
# WAITRESS_CONNECTION_LIMIT=200
# WAITRESS_CHANNEL_TIMEOUT=120

# --- WhatsApp Business API ---
WHATSAPP_VERIFY_TOKEN=your-custom-verify-string
META_APP_ID=
META_APP_SECRET=
WHATSAPP_EMBEDDED_CONFIG_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_NUMBER=+231775323731
WHATSAPP_NOTIFY_NUMBER=231775323731
WHATSAPP_AUTO_REPLY=true
WHATSAPP_AI_REPLY=true

# --- OpenAI (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Local call tracker (shop PC → cloud ERP) ---
LOCAL_API_KEY=your-secret-api-key
LOCAL_API_URL=https://erp.yourdomain.com/api/communications/log

# --- Twilio voice (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ASSEMBLYAI_API_KEY=

# --- Email (optional) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Ghost admin / emergency recovery ---
GHOST_ADMIN_USER=ghost_admin
GHOST_MASTER_RECOVERY_KEY=

# --- Staff alerts (optional) ---
ADMIN_ALERT_PHONE=
