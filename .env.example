# 3G DESIGN ERP — Environment Configuration
# Copy this file to .env and fill in your values.
# Works locally (VS port forwarding) AND on cloud (PythonAnywhere, VPS, etc.)

# --- Core ---
SECRET_KEY=change-this-to-a-long-random-string

# --- Public site URL (REQUIRED for WhatsApp webhook on cloud) ---
# Local with VS port forwarding: https://your-forwarded-url.devtunnels.ms
# PythonAnywhere: auto-detected from PYTHONANYWHERE_DOMAIN (e.g. 3gdesign.pythonanywhere.com)
# Or set explicitly — no space after =, no trailing slash; include username subdomain:
# PUBLIC_SITE_URL=https://3gdesign.pythonanywhere.com
PUBLIC_SITE_URL=

# PythonAnywhere sets PYTHONANYWHERE_DOMAIN automatically; override only if needed:
# PYTHONANYWHERE_SITE=3gdesign.pythonanywhere.com

# Alternative webhook base (same as PUBLIC_SITE_URL if unsure)
WEBHOOK_BASE_URL=

# App port when running locally (run.py reads APP_PORT, default 5001)
APP_PORT=5001

# --- WhatsApp Business API (Meta Developer Console) ---
# Webhook verify token (always required in .env)
WHATSAPP_VERIFY_TOKEN=your-custom-verify-string-here

# Embedded Signup (recommended — one-click connect in Admin → Communications)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
WHATSAPP_EMBEDDED_CONFIG_ID=your-embedded-signup-config-id

# Manual fallback (optional if using Embedded Signup)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_NUMBER=+231775323731
WHATSAPP_NOTIFY_NUMBER=231775323731
WHATSAPP_AUTO_REPLY=true
WHATSAPP_AI_REPLY=true

# Optional: OpenAI for smarter replies (falls back to built-in assistant if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Local call tracker (shop PC) ---
LOCAL_API_KEY=your-secret-api-key
LOCAL_API_URL=http://127.0.0.1:5001/api/communications/log

# --- Twilio voice (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ASSEMBLYAI_API_KEY=

# --- Email (optional) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Ghost admin ---
GHOST_ADMIN_USER=ghost_admin
