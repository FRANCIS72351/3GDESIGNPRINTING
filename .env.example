# Environment Variables for 3G Design Printing
# Copy this file to .env and fill in your values

# Ghost User Configuration
GHOST_ADMIN_USER=ghost_admin

# Master Recovery Key for Ghost User Password Reset
# CHANGE THIS TO A SECURE, UNIQUE KEY!
# NEVER commit the actual key to version control
GHOST_MASTER_RECOVERY_KEY=your_super_secure_recovery_key_here

# Database Configuration (if needed)
# DATABASE_URL=sqlite:///instance/printing.db

# Flask Configuration
# FLASK_ENV=production
# SECRET_KEY=your_flask_secret_key_here